module.exports = {"az_tonto_5830.jpg":{"title":"Tonto National Monument","text":"The view from lower cliff toward Roosevelt Lake. Although it's a national forest, we cannot find any 'tree' there. Picture took in Arizona, 2019-10."},"az_tonto_5850.jpg":{"title":"Burnt Cactus","text":"These cactuses were burnt in a fire before we took this picture."},"JKC_5134.jpg":{"title":"Horse in Disney","text":"A tired horse in California Disney land, such a beautiful place. Should go there again and again until our dream come true."},"JKC_5205.jpg":{"title":"Pumpkin in Disney","text":"Badass pumpkins running a cart in California Disney land. Yet the role to enter entertainment facility was way too long. I guess these pumpkins were the staffs who dead from overwork at last Halloween."},"JKC_4883.jpg":{"title":"Patrol SUV","text":"“Did I went into GTA V?” - Santa Monica. How come all good wether goto Los Angeles and left Arizona as a hot pan land?"},"JKC_4875.jpg":{"title":"Beach","text":"“No Trevor Philips” - A beach as you seen in GTA V, with more and more and more people laying on there tiny tower."},"dam.jpg":{"title":"Roosevelt Dam","text":"Seems like it will control the salt river."},"gcfull.jpg":{"title":"The Great Canyon","text":"No need description."},"JKC_4932.jpg":{"title":"Sunset","text":"Sunset at Griffith Observatory."},"JKC_5004.jpg":{"title":"Sunset 2","text":"Sunset at Griffith Observatory."},"JKC_5257.jpg":{"title":"Curry (Japanese)","text":"Seems like no one know this kind of curry in US. Why? No rice? Go find Uncle Roger."},"JKC_5248.jpg":{"title":"Bread pudding","text":"It tastes bad. I don't know why, maybe I forgot to check the recipe again before sent it into oven."},"card-sample.png":{"title":"Card Showcase","text":"None of the thing in this picture is real. Violin was modeled by me, and the card, generated bellow, are rendered in Blender. Yes, I do play violin."}}